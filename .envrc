dotenv_if_exists .env

export OPS_PRIVATE_DIR="${OPS_PRIVATE_DIR:-$HOME/Ops/ops-private}"
export SOPS_AGE_SSH_PRIVATE_KEY_FILE="${SOPS_AGE_SSH_PRIVATE_KEY_FILE:-$HOME/.ssh/id_rsa}"

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  log_status "OPENAI_API_KEY is not set; copy .env.example to .env and add the rotated key"
fi
