{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "euclid-catalog": {
      "type": "remote",
      "url": "http://euclid-catalog-mcp.data-and-computing.svc.cluster.local:8000/mcp",
      "enabled": true
    },
    "astro_k3s_mcp": {
      "type": "remote",
      "url": "http://eva24002-entrance.lab.zverse.space:30082/mcp",
      "enabled": true,
      "oauth": false,
      "timeout": 15000
    },
    "fits-cutout": {
      "type": "remote",
      "url": "https://fits-cutout.mcp.ay.dev:32443/mcp",
      "enabled": true,
      "timeout": 600000
    }
  },
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://sub2api.home.geekcity.tech:32443/v1",
        "apiKey": "{env:AI_MODEL_KEY}"
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    }
  },
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.3-codex",
  "plugin": [
    "opencode-plugin-langfuse"
  ],
  "experimental": {
    "openTelemetry": true
  },
  "agent": {
    "build": {
      "options": {
        "store": false
      }
    },
    "plan": {
      "options": {
        "store": false
      }
    },
    "orchestrator-agent": {
      "permission": {
        "question": "allow"
      }
    },
    "filter-agent": {
      "permission": {
        "question": "allow"
      }
    }
  }
}
