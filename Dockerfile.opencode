FROM m.daocloud.io/docker.io/library/node:20-bookworm-slim AS builder

ARG OPENCODE_VERSION=1.18.2

RUN unset HTTP_PROXY HTTPS_PROXY http_proxy https_proxy ALL_PROXY && \
    npm config set proxy false && \
    npm config set https-proxy false && \
    npm install -g "opencode-ai@${OPENCODE_VERSION}" && \
    npm cache clean --force

FROM m.daocloud.io/docker.io/library/node:20-bookworm-slim AS runtime

ARG OPS_AGENT_VERSION=0.1.0
ARG OPENCODE_VERSION=1.18.2
ARG KUBECTL_VERSION=v1.34.6

LABEL org.opencontainers.image.title="Ops Agent" \
      org.opencontainers.image.version="${OPS_AGENT_VERSION}" \
      io.opencode.version="${OPENCODE_VERSION}"

RUN unset HTTP_PROXY HTTPS_PROXY http_proxy https_proxy ALL_PROXY && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      bash \
      ca-certificates \
      curl \
      git \
      jq \
      openssh-client \
      tini && \
    rm -rf /var/lib/apt/lists/* && \
    curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl" && \
    curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl.sha256" && \
    printf '%s  kubectl\n' "$(cat kubectl.sha256)" | sha256sum -c - && \
    install -m 0755 kubectl /usr/local/bin/kubectl && \
    rm kubectl kubectl.sha256 && \
    groupmod --new-name opencode node && \
    usermod --login opencode --home /home/opencode --move-home --shell /bin/bash node

COPY --from=builder /usr/local/lib/node_modules/opencode-ai/node_modules/opencode-linux-x64/bin/opencode /usr/local/bin/opencode
COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh

RUN chmod 0755 /usr/local/bin/docker-entrypoint.sh && \
    mkdir -p /home/opencode/.cache/opencode /workspace && \
    chown -R opencode:opencode /home/opencode /workspace

USER opencode
ENV HOME=/home/opencode \
    XDG_CACHE_HOME=/home/opencode/.cache \
    OPENCODE_DISABLE_AUTOUPDATE=true

# Resolve plugins during the image build so Pod startup does not depend on npm.
RUN OPENCODE_CONFIG_CONTENT='{"plugin":["opencode-vibeguard@0.1.0","@tarquinen/opencode-dcp@3.1.14"],"share":"disabled"}' \
    opencode debug config >/dev/null

WORKDIR /workspace
EXPOSE 4000

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/docker-entrypoint.sh"]
CMD ["opencode", "serve", "--hostname", "0.0.0.0", "--port", "4000", "--print-logs", "--log-level", "INFO"]
